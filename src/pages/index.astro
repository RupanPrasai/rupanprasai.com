---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../site.config';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latestPosts = posts.slice(0, 2);

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rupan Prasai',
  url: siteConfig.domain,
  sameAs: [siteConfig.socialLinks.linkedin, siteConfig.socialLinks.medium, siteConfig.socialLinks.github],
  jobTitle: 'Software Engineer',
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'University of Colorado Boulder'
  }
};
---

<BaseLayout
  title="Rupan Prasai | Software Engineer"
  description="Rupan Prasai is a Software Engineer in the United States with an M.S. in Computer Science, building reliable products, backend systems, and developer workflows."
  canonicalPath="/"
>
  <h1>Rupan Prasai</h1>
  <p class="meta hero-tagline">Software Engineer based in the United States with an M.S. in Computer Science.</p>

  <p>
    I’m Rupan Prasai, a software engineer focused on building reliable web products, backend systems, and practical developer tooling.
    I care about clean architecture, predictable delivery, and software that stays maintainable as teams and usage grow.
    Explore my <a href="/projects">Projects</a> and <a href="/blog">Blog</a> for examples of what I build and how I think.
  </p>

  <section aria-labelledby="featured-projects">
    <h2 id="featured-projects">Featured Projects</h2>
    <div class="card-grid">
      {siteConfig.projects.map((project) => (
        <article class="card">
          <h3><a href={project.url}>{project.name}</a></h3>
          <p>{project.description}</p>
          <p class="meta">{project.techStack.join(' · ')}</p>
        </article>
      ))}
    </div>
    <p><a href="/projects">See all project details on the Projects page.</a></p>
  </section>

  <section aria-labelledby="latest-writing">
    <h2 id="latest-writing">Latest Writing</h2>
    <div class="card-grid">
      {latestPosts.map((post) => (
        <article class="card">
          <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
          <p class="meta">
            <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          </p>
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
    <p><a href="/blog">Browse all posts.</a></p>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
</BaseLayout>
