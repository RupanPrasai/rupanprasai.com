---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout
  title="Blog | RUPAN PRASAI on Software Engineering"
  description="Read writing by RUPAN PRASAI on practical software engineering, reliability, and the habits that support sustainable delivery."
  canonicalPath="/blog"
>
  <h1>Blog</h1>
  <p>Notes on software engineering, systems thinking, and practical delivery.</p>

  <div class="card-grid">
    {posts.map((post) => (
      <article class="card">
        <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
        <p class="meta">
          <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        </p>
        <p>{post.data.description}</p>
      </article>
    ))}
  </div>
</BaseLayout>
