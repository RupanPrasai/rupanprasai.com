---
import { siteConfig } from '../site.config';
---

<header>
  <div class="container nav">
    <a href="/" aria-label="Go to homepage"><strong>{siteConfig.fullName}</strong></a>
    <nav class="nav-links" aria-label="Main">
      <a href="/about">About</a>
      <a href="/projects">Projects</a>
      <a href="/blog">Blog</a>
      <a href="/photos">Photos</a>
      <a href="/contact">Contact</a>
      <a href={siteConfig.socialLinks.linkedin} target="_blank" rel="noopener noreferrer me">LinkedIn</a>
      <a href={siteConfig.socialLinks.medium} target="_blank" rel="noopener noreferrer me">Medium</a>
      <a href={siteConfig.socialLinks.youtube} target="_blank" rel="noopener noreferrer me">YouTube</a>
      <a href={siteConfig.socialLinks.github} target="_blank" rel="noopener noreferrer me">GitHub</a>
    </nav>
  </div>
</header>
